# Rallys Equities backend configuration (all optional)

# Server port (default 5174)
PORT=5174

# Bearer token for /admin and /api/admin/* (a random one is generated each boot if unset)
ADMIN_TOKEN=change-me

# Email notifications for new submissions (disabled unless SMTP_HOST + NOTIFY_TO are set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_TO=hello@rallysequities.com
